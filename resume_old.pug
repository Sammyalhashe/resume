doctype html
html
    head
        title= resume
        style
            include resume.css
    body

        // Left panel
        .w3-content(style={'max-width':'1400px', height:'auto'})
            .w3-third
                .w3-white.w3-text-grey.w3-card-4
                    .profile.w3-display-container
                        .w3-display-topleft.w3-container.w3-text-black
