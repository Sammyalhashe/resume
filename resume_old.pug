                    .w3-large.w3-text-theme.website
                        b
                            i.fab.fa-chrome.fa-fw.w3-margin-right.w3-text-teal
                            | Website
                        p
                            a(href='www.sammyalhashemi.com') www.sammyalhashemi.com
