                        //-i.fa.fa-home.fa-fw.w3-margin-right.w3-large.w3-text-teal
                        //-| Mississauga, Ontario, Canada
                    p.info-zone
                        i.fa.fa-envelope.fa-fw.w3-margin-right.w3-large.w3-text-teal
                        | sammy.alhashemi@mail.utoronto.ca
                    p.info-zone
                        i.fa.fa-phone.fa-fw.w3-margin-right.w3-large.w3-text-teal
                        | (647)-463-2638
